{
  "$schema": "./node_modules/knip/schema.json",
  "entry": [
    "src/main.js",
    "vite.config.js",
    "postcss.config.js",
    "tailwind.config.js",
    "e2e/playwright.config.ts",
    "e2e/helpers/global-setup.ts",
    "e2e/tests/**/*.ts",
    "e2e/docs-shots/playwright.config.ts",
    "e2e/docs-shots/setup.ts",
    "e2e/docs-shots/shots/**/*.ts",
    "acceptance/playwright.config.ts",
    "acceptance/helpers/global-setup.ts",
    "acceptance/tests/**/*.ts"
  ],
  "project": [
    "src/**/*.{js,ts,vue}",
    "e2e/**/*.ts",
    "acceptance/**/*.ts",
    "*.config.{js,ts}"
  ],
  "ignore": [
    "dist/**",
    "node_modules/**",
    "playwright-report/**",
    "test-results/**",
    "e2e/.auth/**",
    "e2e/docs-shots/.auth/**",
    "e2e/docs-shots/.artifacts/**",
    "e2e/docs-shots/out/**",
    "acceptance/.auth/**",
    "acceptance/playwright-report/**"
  ],
  "ignoreDependencies": [
    "@crabnebula/tauri-plugin-drag",
    "@tauri-apps/cli",
    "vue-virtual-scroll-grid"
  ]
}
