# Example environment variables
# Copy to .env and customize if needed

# Optional VLM endpoint. Most settings are managed in config.yaml / Settings UI.
VLM_ENDPOINT=http://127.0.0.1:8001/v1
VLM_MODEL=your-vlm-model
VLM_API_KEY=dummy

# Local development ports used by tools/stimma
HOST=127.0.0.1
STIMMA_BACKEND_PORT=9191
STIMMA_FRONTEND_PORT=9192

# Logging
LOG_LEVEL=INFO
