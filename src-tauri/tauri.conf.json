{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "Stimma",
  "version": "0.1.0",
  "identifier": "ai.stimma.stimma.debug",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:9192",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Stimma",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "macOS": {
      "entitlements": "Entitlements.plist"
    },
    "externalBin": [
      "binaries/stimma-watchdog"
    ],
    "resources": {
      "binaries/stimma-backend-aarch64-apple-darwin": "stimma-backend"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "dialog": false,
      "pubkey": "STIMMA_UPDATER_PUBKEY_PLACEHOLDER",
      "endpoints": [
        "https://updates.stimma.ai/stimma/production/darwin-aarch64/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
